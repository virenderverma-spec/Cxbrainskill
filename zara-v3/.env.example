# Databricks SQL
DATABRICKS_HOST=https://dbc-b7af8d94-a7ba.cloud.databricks.com
DATABRICKS_TOKEN=your-databricks-token
DATABRICKS_WAREHOUSE_ID=your-warehouse-id

# Databricks Brand Detection (optional — column may not exist yet)
DATABRICKS_BRAND_TABLE=rds-prod_catalog.cj_prod.customer_brand_mapping
DATABRICKS_BRAND_COLUMN=brand

# Boss API
BOSS_API_URL=https://prod-boss-api.rockstar-automations.com
BOSS_API_KEY=your-boss-api-key

# Anthropic (optional — enables AI query)
# ANTHROPIC_API_KEY=sk-ant-...

# Zendesk
ZENDESK_SUBDOMAIN=your-subdomain
ZENDESK_EMAIL=your-email@example.com
ZENDESK_TOKEN=your-zendesk-api-token

# v2: Proactive Scanner
SCANNER_ENABLED=false
SCANNER_INTERVAL_MS=900000

# v2: ConnectX API (IMEI check + provisioning logs)
CONNECTX_API_URL=https://connectx-api.internal.meowmobile.com
CONNECTX_API_TOKEN=your-connectx-token

# v2: NW Outage Checker (live carrier network status)
NW_OUTAGE_CHECKER_URL=https://nw-outage-checker.internal.meowmobile.com

# v2: Zendesk Custom Field IDs
# Sandbox:
# ZENDESK_FIELD_INQUIRY_TYPE=custom_field_13987456
# ZENDESK_FIELD_MSISDN=custom_field_13987501
# Production:
ZENDESK_FIELD_INQUIRY_TYPE=custom_field_14002301
ZENDESK_FIELD_MSISDN=custom_field_14002356
ZENDESK_FIELD_DISPOSITION=custom_field_14002890

# PostHog (optional)
# POSTHOG_API_KEY=phx_...
# POSTHOG_PROJECT_ID=268408
